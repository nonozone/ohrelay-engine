# Worker ingest via engine HTTP
INGEST_PROVIDER=core-http
CORE_INGEST_BASE_URL=http://127.0.0.1:3000
CORE_INGEST_TOKEN=replace-me
FORWARD_TARGET_EMAIL=me@example.com

# Optional alternative ingest mode
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# Engine runtime variables will be added when the engine package is imported.

